# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# krinry
.krinry-cache/

# Firebase — keep the client config out of this PUBLIC repo. It is injected in
# CI from the GOOGLE_SERVICES_JSON secret (base64). Keep your local copy at
# android/app/google-services.json for local builds.
/android/app/google-services.json
google-services.json
**/google-services.json

# Android release signing — NEVER commit the keystore or its passwords.
# Injected in CI from secrets; key.properties created locally/by CI.
/android/key.properties
*.jks
*.keystore
